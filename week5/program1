#include<iostream>
using namespace std;
class addition
{
	private:
		int n;
		int *ptr;
		int sum;
	public:
		void getsize()
		{
			cout<<"enter number of elements:";
			cin>>n;
			ptr=new int[n];
		}
		void getelements()
		{
			cout<<"enter "<<n<<"elements:\n";
			for(int i=0;i<n;i++)
			{
				cin>>ptr[i];
			}
		}
		void calculate()
		{
			sum =0;
			for(int i=0;i<n;i++)
			{
				sum=sum+ptr[i];
			}
		}
		void displaysum()
		{
			cout<<"sum of elements ="<<sum<<endl;
		}
		~addition()
		{
			delete []ptr;
		}
};
 int main()
 {
 	addition obj;
 	obj.getsize();
 	obj.getelements();
 	obj.calculate();
 	obj.displaysum();
 	return 0;
 	
 }
